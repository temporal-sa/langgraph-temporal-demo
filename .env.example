# ── Demoer quick-switch: copy to .env and fill in. Env vars only — never code. ──

# Temporal connection (local dev server defaults; flip for Temporal Cloud)
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
# Compose deliberately uses the host gateway instead of TEMPORAL_ADDRESS.
# Override only when containers should connect somewhere else.
# COMPOSE_TEMPORAL_ADDRESS=host.docker.internal:7233
# COMPOSE_WEB_PORT=5173
# COMPOSE_API_PORT=8002
# COMPOSE_POSTGRES_PORT=5432
# Optional: task queue for the Temporal + LangGraph variant.
# LANGGRAPH_TEMPORAL_TASK_QUEUE=support-agent-temporal-langgraph
# TEMPORAL_API_KEY=                # Temporal Cloud (API-key auth; implies TLS)
# TEMPORAL_TLS=true                # Set true for TLS without mTLS files
# TEMPORAL_TLS_CERT=/path/cert.pem # Temporal Cloud (mTLS) — set both cert and key
# TEMPORAL_TLS_KEY=/path/key.pem

# Database (docker compose up -d gives you this)
DB_URL=postgresql://demo:demo@localhost:5432/chinook
# Compose Postgres settings.
# POSTGRES_INIT_DB=postgres
# APP_DB_NAME=chinook
# POSTGRES_USER=demo
# POSTGRES_PASSWORD=demo
# POSTGRES_PASSWORD_URLENCODED=demo

# LLM provider: anthropic (default) | openai
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-6
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o
# Optional: simulate random OpenAI API failures in the LangGraph app.
# 0 disables it; 1 makes every OpenAI planning call fail.
# OPENAI_FAILURE_RATE=0.2

# HTTP/API deployment settings.
# PORT=8002
# BACKEND_URL=http://backend:8000  # worker-only private service URL
# CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:8080

# Optional public-demo access gate. Set this in deployed environments so the API
# is not an unauthenticated proxy to paid LLM providers. Leave unset for local dev.
# DEMO_ACCESS_TOKEN=
# DEMO_AUTH_REQUIRED=true       # Fail startup if the public-demo token is missing
# DEMO_AUTH_DISABLED=false

# Frontend container config. Local static development can keep web/config.js.
# DEFAULT_AGENT_BACKEND=temporal-langgraph
# TEMPORAL_BACKEND_URL=http://localhost:8000
# LANGGRAPH_BACKEND_URL=http://localhost:8001
# TEMPORAL_LANGGRAPH_BACKEND_URL=http://localhost:8002
# TEMPORAL_UI_URL=http://localhost:8233
